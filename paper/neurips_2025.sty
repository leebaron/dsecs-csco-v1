% neurips_2025.sty — NeurIPS 2025 style file (minimal-compatible subset)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 style]

\RequirePackage{times}
\RequirePackage[letterpaper,top=1in,left=1in,right=1in,bottom=1in]{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{lastpage}

% Title formatting
\def\@maketitle{
  \begin{center}
    {\LARGE\bfseries \@title \par}
    \vskip 0.5em
    {\large
      \begin{tabular}[t]{c}
        \@author
      \end{tabular}
    \par}
    \vskip 1em
  \end{center}
}

% Abstract
\renewenvironment{abstract}{%
  \begin{center}
  \bfseries\large\abstractname
  \end{center}
  \vspace{0.5em}
  \begin{quote}
}{%
  \end{quote}
  \vspace{1em}
}

% Section formatting
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-3.5ex \@plus -1ex \@minus -.2ex}%
  {2.3ex \@plus.2ex}%
  {\normalfont\Large\bfseries}}

\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1.5ex \@plus .2ex}%
  {\normalfont\large\bfseries}}

% Header/footer
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}

% Algorithmic package compatibility
\floatname{algorithm}{Algorithm}
\renewcommand{\algorithmicrequire}{\textbf{Input:}}
\renewcommand{\algorithmicensure}{\textbf{Output:}}

% Verbatim
\RequirePackage{verbatim}
